# ── Local Development ──────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Individual DB vars (used when DATABASE_URL is not set)
DB_NAME=retail_portal
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# ── Production (Render) ────────────────────────────────────────────────────────
# Render injects DATABASE_URL automatically from the linked managed database.
# Set the remaining vars manually in the Render dashboard:
#
# SECRET_KEY=<generate a strong random key>
# DEBUG=False
# ALLOWED_HOSTS=.onrender.com
# DATABASE_URL=<auto-injected by render.yaml fromDatabase>
